# Copy to .env and fill in all values. Never commit .env.

# PostgreSQL — used by docker-compose for the postgres service; credentials must match DATABASE_URL below.
POSTGRES_USER=tostikaart
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=tostikaart

# App / local `go run`: host is localhost. In docker-compose the app service overrides DATABASE_URL to use hostname `postgres`.
DATABASE_URL=postgres://tostikaart:change-me-strong-password@localhost:5432/tostikaart?sslmode=disable
MIGRATIONS_DIR=migrations
LISTEN_ADDR=:8080

# Public URL of this app (no trailing slash)
# PUBLIC_BASE_URL=https://example.com

# Google OAuth (Web client). Redirect URI must match exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Only this Workspace / Gmail domain may log in (lowercase, no @)
ALLOWED_GOOGLE_DOMAIN=example.com

# At least 32 random characters
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Optional: 32+ chars; defaults to SHA-256 of SESSION_SECRET
# CSRF_AUTH_KEY=

# Production HTTPS: set COOKIE_SECURE=true, or use cloudflared / a reverse proxy with:
# TRUST_PROXY_HEADERS=true (sends X-Forwarded-Proto: https) to force Secure cookies + HSTS.
# If someone uses http:// on the tunnel, X-Forwarded-Proto is http; the app then 308-redirects
# to HTTPS (uses PUBLIC_BASE_URL when set to https://..., else https:// + forwarded Host).
COOKIE_SECURE=false
# TRUST_PROXY_HEADERS=false

# Payments (shown on /buy). Admins can override with a stored URL under Admin → Instellingen.
TIKKIE_URL=
# Shown on /buy and snapshotted on each payment accorderen (historische omzet blijft kloppen bij tariefwijziging).
PAYMENT_AMOUNT_EUR=15
BANK_TRANSFER_INSTRUCTIONS=IBAN: NL00 BANK 0123 4567 89\nTen name van: ...

# Comma-separated emails that become admin on every login (lowercase)
BOOTSTRAP_ADMIN_EMAILS=you@example.com
